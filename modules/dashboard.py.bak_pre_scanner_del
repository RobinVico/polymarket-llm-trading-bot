</select>
<select id="tier-{{ loop.index0 }}" class="conf-sel" title="止损分级 (Claude 入场分类决定): 真相收敛 -20% / 混合 -35% / 事件驱动 不止损只用 $0.05 地板" onchange="saveTier('{{ p.asset }}', this.value)">
