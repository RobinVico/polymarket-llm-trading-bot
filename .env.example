# Polymarket 钱包凭证 (必填)
# 从 https://polymarket.com/profile 拿
POLY_PRIVATE_KEY=0x_your_private_key_here
POLY_FUNDER=0x_your_funder_address_here

# 签名类型
# 0 = EOA wallet
# 1 = Magic/Email wallet (POLY_GNOSIS_SAFE)
# 2 = Polymarket Proxy Wallet
POLY_SIGNATURE_TYPE=1

# CLOB API 凭证 (运行后由 py-clob-client 自动生成,可留空)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
