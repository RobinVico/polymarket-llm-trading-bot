def build_reeval_prompt(meta, cur_price, days_to_resolution, progress_pct=None):
    """根据仓位元数据填充重评 prompt (v4)"""
    raw = meta.get("claude_raw_estimate")
    raw_line = f"原始 raw estimate (集成前): {raw*100:.1f}%" if raw else ""
    
    reason = (meta.get("entry_reason") or "").strip()
    if reason:
        reason_block = f"""\n【你之前的入场理由】\n{reason}\n\n请评估: 这个理由现在还成立吗?有没有新信息支持或反驳它?\n"""
    else:
        reason_block = ""
    
    # 当下 edge
    q = meta.get("new_tp") or meta.get("tp") or 0
    edge_pp = (q - cur_price) * 100
    
    # confidence 例外条款
    confidence = (meta.get("original_confidence") or "").lower()
    if confidence == "low":
        exception_clause = (
            "原始研究 confidence=low: 你可以基于'我之前估高了'的元认知主动下调 q,\n"
            "下调幅度 ≤5pp 时无需新信息. 超过 5pp 的下调仍必须有新信息支持."
        )
        confidence_label = "low (允许 ≤5pp 元认知调整)"
    elif confidence == "medium":
        exception_clause = (
            "原始研究 confidence=medium: 默认规则适用 (必须有新信息).\n"
            "若你确信原始研究有逻辑漏洞, 可下调 ≤3pp 不需新信息."
        )
        confidence_label = "medium"
    else:
        exception_clause = "原始研究 confidence=high (或未标注): 必须有新信息支持任何 q 的调整, 无例外."
        confidence_label = confidence or "(未标注, 默认 high)"
    
    return REEVAL_PROMPT.format(
        market_slug=meta.get("market_slug", "(未知)"),
        side=meta.get("side", "?"),
        entry_price_pct=meta.get("entry_price", 0) * 100,
        entry_date=(meta.get("created_at", "") or "")[:10],
        cur_price_pct=cur_price * 100,
        days_to_resolution=days_to_resolution,
        tp_pct=q * 100,
        edge_pp=edge_pp,
        confidence_label=confidence_label,
        raw_estimate_line=raw_line,
        entry_reason_block=reason_block,
        exception_clause=exception_clause,
    )

